{
  "name": "@no-witness-labs/hydra-sdk",
  "version": "0.0.4",
  "description": "TypeScript SDK for the Cardano Hydra Head protocol — head lifecycle, WebSocket transport, and L2 provider",
  "type": "module",
  "license": "MIT",
  "author": "No Witness Labs",
  "homepage": "https://github.com/no-witness-labs/hydra-sdk/tree/main/packages/hydra-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/no-witness-labs/hydra-sdk.git",
    "directory": "packages/hydra-sdk"
  },
  "bugs": {
    "url": "https://github.com/no-witness-labs/hydra-sdk/issues"
  },
  "keywords": [
    "cardano",
    "hydra",
    "hydra-head",
    "layer2",
    "l2",
    "websocket",
    "typescript",
    "effect",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/Provider/index.d.ts",
      "import": "./dist/Provider/index.js",
      "default": "./dist/Provider/index.js"
    },
    "./mesh-provider": {
      "types": "./dist/Provider/MeshProvider.d.ts",
      "import": "./dist/Provider/MeshProvider.js",
      "default": "./dist/Provider/MeshProvider.js"
    }
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "dev": "tsc -b tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src test --ignore-pattern test/browser",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:browser": "playwright test --config ../../playwright.config.ts",
    "docgen": "docgen",
    "clean": "rm -rf dist .turbo .tsbuildinfo"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@no-witness-labs/hydra-devnet": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "dockerode": "^4.0.10",
    "vitest-websocket-mock": "^0.5.0"
  },
  "peerDependencies": {
    "@evolution-sdk/evolution": ">=0.3.22",
    "@meshsdk/common": ">=1.8.0"
  },
  "peerDependenciesMeta": {
    "@evolution-sdk/evolution": {
      "optional": true
    },
    "@meshsdk/common": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "ws": "^8.20.0"
  }
}
