{
  "name": "@no-witness-labs/hydra-sdk-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI for managing Cardano Hydra heads — lifecycle commands, UTxO queries, and interactive TUI",
  "license": "MIT",
  "author": "No Witness Labs",
  "homepage": "https://github.com/no-witness-labs/hydra-sdk/tree/main/packages/hydra-sdk-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/no-witness-labs/hydra-sdk.git",
    "directory": "packages/hydra-sdk-cli"
  },
  "bugs": {
    "url": "https://github.com/no-witness-labs/hydra-sdk/issues"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "hydra": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps && chmod +x dist/index.js",
    "build:binary": "bun run build.ts",
    "start": "pnpm build && node dist/index.js",
    "dev": "tsc -b tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "clean": "rm -rf dist bin .turbo .tsbuildinfo"
  },
  "keywords": [
    "cardano",
    "hydra",
    "hydra-head",
    "cli",
    "layer2",
    "l2"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@effect/cli": "^0.76.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-node": "^0.108.0",
    "@evolution-sdk/evolution": "^0.5.11",
    "@no-witness-labs/hydra-sdk": "workspace:*",
    "ink": "^7.1.1",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "vitest-websocket-mock": "^0.7.0"
  }
}
