{
  "name": "@no-witness-labs/hydra-sdk-cli",
  "version": "0.0.5",
  "type": "module",
  "description": "",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "hydra": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps && chmod +x dist/index.js",
    "start": "pnpm build && node dist/index.js",
    "dev": "tsc -b tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo .tsbuildinfo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.4",
    "@effect/platform-node": "^0.104.1",
    "@evolution-sdk/evolution": ">=0.3.25",
    "@no-witness-labs/hydra-sdk": "workspace:*",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.14",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "vitest-websocket-mock": "^0.5.0"
  }
}
