{
  "name": "@no-witness-labs/hydra-sdk-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the Hydra SDK — a TypeScript SDK for the Cardano Hydra Head protocol",
  "type": "module",
  "license": "MIT",
  "author": "No Witness Labs",
  "homepage": "https://github.com/no-witness-labs/hydra-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/no-witness-labs/hydra-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/no-witness-labs/hydra-sdk/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://projectcatalyst.io"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "test": "turbo test",
    "coverage": "turbo test -- --coverage",
    "clean": "turbo clean && rimraf packages/*/dist packages/*/.turbo",
    "circular": "madge --circular --extensions ts packages/*/src/index.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:dry-run": "pnpm build && changeset publish --dry-run",
    "docgen": "turbo docgen"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/vitest": "^0.29.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.9.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "effect": "^3.19.15"
  },
  "dependencies": {
    "@effect/docgen": "^0.5.2",
    "@effect/platform": "^0.96.2"
  },
  "pnpm": {}
}
